{
  "expo": {
    "name": "UseItUp",
    "slug": "useitup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D6A4F"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "UseItUp needs camera access to scan barcodes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2D6A4F"
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D6A4F"
      },
      "package": "com.useitup.app",
      "permissions": [
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "VIBRATE"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.useitup.app",
      "infoPlist": {
        "NSCameraUsageDescription": "UseItUp needs camera access to scan barcodes.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.815639717206-0qpbus5qfk5u05kmcnhm844vc0hea28v"
            ]
          }
        ]
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
